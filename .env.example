# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "Your App Name"

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "light"

# chat ui mode: pi | legacy
CHAT_UI = "pi"
# 独立 pi-agent web-ui 入口；本地默认是 http://localhost:5173，生产部署后改成线上地址
PI_AGENT_WEB_URL = "http://localhost:5173"
