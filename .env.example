RATE_LIMIT_USER_WINDOW_MS = "60000"
RATE_LIMIT_USER_MAX = "40"
RATE_LIMIT_DAILY_USER_MAX = "800"
RATE_LIMIT_STORE = "memory"
RATE_LIMIT_FAILURE_MODE = "fail-open"
RATE_LIMIT_REDIS_PREFIX = "icai"
