# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "Your App Name"

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "light"

# chat ui mode: pi | legacy
CHAT_UI = "pi"
# 可选：把 /chat 反向代理到独立 pi-web-ui 服务（示例：http://127.0.0.1:5173）
PI_WEB_UI_PROXY_ORIGIN = ""

# database
DATABASE_URL = ""
DATABASE_PROVIDER = "postgresql"
DB_SINGLETON_ENABLED = "true"

# auth secret
# openssl rand -base64 32
AUTH_SECRET = ""

# ingest (for external apps, e.g. Harvey -> IC-AI)
INTEGRATION_INGEST_API_KEY = ""
