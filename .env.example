SUPABASE_SSH_WEB_URL = "http://localhost:3003"
FUMADOCS_WEB_URL = "http://localhost:3002/docs"
# 可选：把 /chat 反向代理到独立 pi-web-ui 服务（示例：http://127.0.0.1:5173）
PI_WEB_UI_PROXY_ORIGIN = ""

# Pi Agent local BFF -> Dify -> Barbot usage reporting
# Barbot historically reads DIFY_API_URL, while Pi BFF reads DIFY_BASE_URL.
# Keep both names aligned in production.
DIFY_API_URL = "http://156.224.28.114/v1"
DIFY_BASE_URL = "http://156.224.28.114/v1"
DIFY_API_KEY = ""
BARBOT_USAGE_TOKEN = ""
BARBOT_USAGE_PRODUCT = "pi-web-ui"
BARBOT_USAGE_APP_ID = "pi-web-ui"
BARBOT_USAGE_MODEL = "mcuAgent_v2"
BARBOT_USAGE_PROVIDER = "dify"

# database
DATABASE_URL = "postgresql://postgres.kpnfckumhfutdptztylr:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres"
DATABASE_PROVIDER = "postgresql"
DB_SINGLETON_ENABLED = "true"

# payment settings can also be stored in the admin config table.
