# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "Your App Name"

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "light"

# chat ui mode: pi | legacy
CHAT_UI = "pi"
# 可选：把 /chat 反向代理到独立 pi-web-ui 服务（示例：http://127.0.0.1:5173）
PI_WEB_UI_PROXY_ORIGIN = ""

# database
DATABASE_URL = ""
DATABASE_PROVIDER = "postgresql"
DB_SINGLETON_ENABLED = "true"

# auth secret
# openssl rand -base64 32
AUTH_SECRET = ""

# ingest (for external apps, e.g. Harvey -> IC-AI)
INTEGRATION_INGEST_API_KEY = ""

# rate limit (api/chat)
RATE_LIMIT_IP_WINDOW_MS = "60000"
RATE_LIMIT_IP_MAX = "60"
RATE_LIMIT_USER_WINDOW_MS = "60000"
RATE_LIMIT_USER_MAX = "40"
RATE_LIMIT_DAILY_USER_MAX = "800"
RATE_LIMIT_STORE = "memory"
RATE_LIMIT_FAILURE_MODE = "fail-open"
RATE_LIMIT_REDIS_PREFIX = "icai"
REDIS_REST_URL = ""
REDIS_REST_TOKEN = ""

# observability
SENTRY_DSN = ""
ALERT_WEBHOOK_URL = ""
ALERT_WINDOW_MS = "300000"
ALERT_MIN_REQUESTS = "30"
ALERT_ERROR_RATE_THRESHOLD = "0.05"
ALERT_P95_LATENCY_MS = "2000"
ALERT_COOLDOWN_MS = "300000"
OPS_SIMULATE_TOKEN = ""

# cost guard
COST_GUARD_DAILY_TOKENS_MAX = "0"
COST_GUARD_DAILY_COST_MAX = "0"
COST_GUARD_DAILY_MODEL_TOKENS_MAX = "0"

# security headers
SECURITY_HEADERS_HSTS = "max-age=63072000; includeSubDomains; preload"
SECURITY_HEADERS_X_FRAME_OPTIONS = "DENY"
SECURITY_HEADERS_REFERRER_POLICY = "strict-origin-when-cross-origin"
SECURITY_HEADERS_CSP = ""

# comma-separated list, e.g. cdn.example.com,images.example.com
NEXT_PUBLIC_ALLOWED_IMAGE_HOSTS = ""
