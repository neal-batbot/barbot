  "introduce": {
    "block": "features-list",
    "id": "introduce",
    "title": "BatBot 是什么",
    "label": "平台简介",
    "description": "BatBot 维护一套可组合的 Agentic 架构。接入你的行业知识——技术文档、标准规范、企业私有数据——平台即成为该行业的 AI 专家。同一套系统驱动每个垂直行业。",
    "image": {
      "src": "/imgs/features/landing-page.png",
      "alt": "BatBot 平台概览"
    },
    "items": [
      {
        "title": "自研虚拟文件系统",
        "description": "不只是存储。从底层为 Agentic 检索设计的结构化知识引擎，版本可控、来源可溯、实时可查。",
        "icon": "RiDatabase2Line",
        "image": {
          "src": "/imgs/features/1.png",
          "alt": "虚拟文件系统"
        }
      },
      {
        "title": "面向工程师的文档站",
        "description": "Agent 查的，工程师也能直接看到。支持浏览、参数搜索、引用溯源，工程师每天真实使用。",
        "icon": "RiBookOpenLine",
        "image": {
          "src": "/imgs/features/1.png",
          "alt": "工程师文档站"
        }
      },
      {
        "title": "可组合 Agent 推理层",
        "description": "基于虚拟文件系统进行推理，支持问答、代码生成、选型推荐、多步骤任务执行。Token 用量随套餐打包。",
        "icon": "RiRobot2Line",
        "image": {
          "src": "/imgs/features/1.png",
          "alt": "Agent 推理层"
        }
      },
      {
        "title": "换数据，换行业",
        "description": "替换数据集即进入新行业。无需重新训练，无需重复开发，平台自动适配。",
        "icon": "RiRefreshLine",
