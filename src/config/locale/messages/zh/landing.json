  "introduce": {
    "block": "features-list",
    "id": "introduce",
    "title": "我们构建什么",
    "label": "Agentic AI 公司",
    "description": "BatBot 不是把模型包装成聊天框，而是把具体问题拆成知识、工具、权限、模型供应和商业闭环。你完全拥有这套 AI，它运行在你的业务数据、你的产品规则和你的增长模型之上。",
    "image": {
      "src": "/imgs/barbot/what-we-build-v2.png",
      "alt": "BatBot 平台概览"
    },
    "items": [
      {
        "title": "行业知识系统",
        "description": "把文档、规格书、标准、工单和内部经验变成 AI 可检索、可引用、可持续更新的知识底座。",
        "icon": "RiDatabase2Line",
